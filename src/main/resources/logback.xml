<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{20} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- The driver is very chatty at INFO; keep it quiet for a load generator. -->
    <logger name="com.datastax.oss.driver" level="WARN"/>
    <logger name="com.datastax.oss.driver.internal.core.control" level="ERROR"/>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
